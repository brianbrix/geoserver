# ── Domain & TLS ──────────────────────────────────────────────────────────────
# Public domain name for this deployment.
DOMAIN=amp-gis.dgstg.org

# Email address used for Let's Encrypt certificate notifications.
ACME_EMAIL=admin@amp-gis.dgstg.org

# ── GeoServer ─────────────────────────────────────────────────────────────────
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=changeme

# Public base URL that GeoServer uses when generating links (OGC, WMS, etc.)
GEOSERVER_PROXY_BASE_URL=https://amp-gis.dgstg.org/geoserver

# CSRF settings – add any additional domains separated by commas
GEOSERVER_CSRF_WHITELIST=amp-gis.dgstg.org
GEOSERVER_CSRF_DISABLED=true

# Top-level proxy base (used by some GeoServer plugins)
PROXY_BASE_URL=https://amp-gis.dgstg.org
