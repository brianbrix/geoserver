# Environment variables for local development
# Copy this file to .env.local and adjust values as needed

# GeoServer admin credentials (pre-filled in the UI)
VITE_GS_USER=admin
VITE_GS_PASSWORD=admin

# Target URL for the GeoServer REST API proxy used by Vite dev server.
# When running outside Docker point this to your local GeoServer instance.
VITE_GS_TARGET=http://localhost:8080
